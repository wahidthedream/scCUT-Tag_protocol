# ============================================================================
# R Script: Human PBMC only – Nature Methods‑compliant stacked bar plot
# Figure: Cell type proportions for 6 histone marks (scCUT&Tag data)
# ============================================================================

# -------------------------------
# 1. Load required libraries
# -------------------------------
library(ggplot2)
library(reshape2)
library(dplyr)

# -------------------------------
# 2. Global figure parameters (Nature Methods standards)
# -------------------------------
SINGLE_COL_MM <- 89          # single column width
FONT_FAMILY <- "Arial"       # Helvetica equivalent
FONT_SIZE_AXIS_TITLE <- 7    # pt
FONT_SIZE_AXIS_TEXT <- 6     # pt (minimum 5)
FONT_SIZE_LEGEND_TITLE <- 7
FONT_SIZE_LEGEND_TEXT <- 6
FONT_SIZE_PANEL_LABEL <- 8   # pt, bold (if needed)
OUTPUT_DPI <- 300

# Colorblind‑safe palette (Wong, 2011)
COLORBLIND_PAL <- c("#E69F00", "#56B4E9", "#009E73", "#F0E442",
                    "#0072B2", "#D55E00", "#CC79A7", "#999999")

# -------------------------------
# 3. Human PBMC data (your counts)
# -------------------------------
human_data <- data.frame(
  Histone = c("H3K27ac", "H3K27me3", "H3K4me1", "H3K4me2", "H3K4me3", "H3K9me3"),
  B = c(1072, 399, 1046, 586, 683, 745),
  CD4T = c(3664, 1758, 3274, 2618, 2729, 1970),
  CD8T = c(2943, 1785, 2571, 2278, 2432, 1697),
  DC = c(588, 292, 445, 277, 340, 196),
  Mono = c(5173, 2681, 3802, 2655, 2992, 2726),
  NK = c(470, 324, 414, 335, 337, 323),
  otherT = c(1079, 475, 903, 690, 723, 494),
  other = c(620, 518, 315, 136, 150, 153)
)

# Melt to long format and compute percentages per histone
human_long <- melt(human_data, id.vars = "Histone",
                   variable.name = "CellType", value.name = "Count") %>%
  group_by(Histone) %>%
  mutate(Percentage = Count / sum(Count) * 100,
         Histone = factor(Histone, levels = unique(Histone))) %>%
  ungroup()

# Order cell types as in the original table
human_long$CellType <- factor(human_long$CellType,
                              levels = c("B", "CD4T", "CD8T", "DC",
                                         "Mono", "NK", "otherT", "other"))

# -------------------------------
# 4. Generate stacked bar plot
# -------------------------------
p_human <- ggplot(human_long, aes(x = Histone, y = Percentage, fill = CellType)) +
  geom_bar(stat = "identity", position = "stack", width = 0.7,
           color = "black", size = 0.2) +
  scale_fill_manual(values = COLORBLIND_PAL) +
  labs(x = NULL, y = "Percentage of cells (%)", fill = "Cell type") +
  scale_y_continuous(expand = c(0, 0), limits = c(0, 105)) +
  theme_minimal(base_family = FONT_FAMILY) +
  theme(
    axis.line = element_line(color = "black", size = 0.25),
    axis.ticks = element_line(color = "black", size = 0.25),
    axis.ticks.length = unit(0.1, "cm"),
    axis.title.y = element_text(size = FONT_SIZE_AXIS_TITLE,
                                margin = margin(r = 5, unit = "pt")),
    axis.text.x = element_text(size = FONT_SIZE_AXIS_TEXT, angle = 45,
                               hjust = 1, color = "black"),
    axis.text.y = element_text(size = FONT_SIZE_AXIS_TEXT, color = "black"),
    panel.background = element_blank(),
    panel.grid = element_blank(),
    legend.title = element_text(size = FONT_SIZE_LEGEND_TITLE),
    legend.text = element_text(size = FONT_SIZE_LEGEND_TEXT),
    legend.key.size = unit(0.25, "cm"),
    legend.spacing.y = unit(0.05, "cm"),
    plot.margin = margin(t = 10, r = 10, b = 5, l = 5, unit = "pt")
  )

# (Optional: add panel label "a" if needed – uncomment below)
# p_human <- p_human + labs(tag = "a") +
#   theme(plot.tag = element_text(size = FONT_SIZE_PANEL_LABEL, face = "bold",
#                                 family = FONT_FAMILY),
#         plot.tag.position = "top left")

# -------------------------------
# 5. Save the figure
# -------------------------------


#ggsave("output-directory/hPBMC_stackedbar_cellnumber.pdf", plot = p_human,
       device = cairo_pdf,
       width = SINGLE_COL_MM / 25.4,
       height = 80 / 25.4,
       units = "in",
       bg = "white")


# -------------------------------
# 6. Print plot to screen (optional)
# -------------------------------
print(p_human)



# ============================================================================
