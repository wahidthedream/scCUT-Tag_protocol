# ============================================================================
# Generate PDF figures only hPBMC
# hPBMC read counts: log10 heatmap 
# ============================================================================

library(ggplot2)
library(reshape2)
library(dplyr)
library(cowplot)

# Parameters ---------------------------------------------------------------
SINGLE_WIDTH_IN <- 89 / 25.4      # 89 mm to inches
DOUBLE_WIDTH_IN <- 183 / 25.4     # 183 mm to inches
HEIGHT_IN <- 80 / 25.4            # 80 mm to inches
FONT_FAMILY <- "Arial"
FONT_SIZE_AXIS_TEXT <- 6
FONT_SIZE_LEGEND_TITLE <- 7
FONT_SIZE_LEGEND_TEXT <- 6
FONT_SIZE_PANEL_LABEL <- 8

# Data --------------------------------------------------------------------
hPBMC <- data.frame(
  CellType = c("B", "CD4T", "CD8T", "DC", "Mono", "NK", "other", "otherT"),
  H3K27ac  = c(4756267, 12530194, 10377857, 2308019, 32875368, 1674459, 2848137, 3659303),
  H3K27me3 = c(3219277, 15237968, 16637075, 2448704, 22419198, 2333054, 2207418, 4144785),
  H3K4me1  = c(4714594, 13413447, 10186697, 2062722, 14710451, 1501807, 1320937, 3533700),
  H3K4me2  = c(2835009, 13470760, 10914970, 1505190, 11571272, 1303075, 531933, 3524662),
  H3K4me3  = c(2333502, 10503533, 8637597, 1249235, 10268458, 1001261, 390302, 2652270),
  H3K9me3  = c(5447003, 12656737, 10327665, 1218714, 22363944, 1848591, 1519312, 2730822)
)

# Transformations ---------------------------------------------------------
mat <- as.matrix(hPBMC[, -1])
rownames(mat) <- hPBMC$CellType
mat_log <- log10(mat + 1)
mat_scaled <- scale(mat_log, center = TRUE, scale = TRUE)

# Melt data ---------------------------------------------------------------
melted_z <- melt(mat_scaled, varnames = c("CellType", "Histone"), value.name = "Z_score")
melted_z$CellType <- factor(melted_z$CellType, levels = rownames(mat))
melted_z$Histone <- factor(melted_z$Histone, levels = colnames(mat))

melted_log <- melt(mat_log, varnames = c("CellType", "Histone"), value.name = "log10_Count")
melted_log$CellType <- factor(melted_log$CellType, levels = rownames(mat))
melted_log$Histone <- factor(melted_log$Histone, levels = colnames(mat))

# Plot function (to avoid repetition) -------------------------------------
base_theme <- function() {
  theme_minimal(base_family = FONT_FAMILY) +
    theme(
      plot.tag = element_text(size = FONT_SIZE_PANEL_LABEL, face = "bold", family = FONT_FAMILY),
      plot.tag.position = "topleft",
      axis.text.x = element_text(angle = 45, hjust = 1, size = FONT_SIZE_AXIS_TEXT, color = "black"),
      axis.text.y = element_text(size = FONT_SIZE_AXIS_TEXT, color = "black"),
      axis.ticks = element_blank(),
      axis.line = element_blank(),
      panel.grid = element_blank(),
      panel.background = element_blank(),
      legend.title = element_text(size = FONT_SIZE_LEGEND_TITLE),
      legend.text = element_text(size = FONT_SIZE_LEGEND_TEXT),
      legend.key.size = unit(0.35, "cm"),
      legend.position = "right",
      plot.margin = margin(t = 5, r = 10, b = 5, l = 5, unit = "pt")
    )
}

# Log10 plot --------------------------------------------------------------
p_log <- ggplot(melted_log, aes(x = Histone, y = CellType, fill = log10_Count)) +
  geom_tile(color = "white", size = 0.3) +
  scale_fill_gradient(low = "#EFF3FF", high = "#08519C",
                      name = "log-transformed") +
  labs(x = NULL, y = NULL, tag = "b") +
  base_theme()

# Save individual PDFs ----------------------------------------------------
ggsave("output_directory/hPBMC_heatmap_readnumber_log10.pdf", plot = p_log,
       device = cairo_pdf, width = SINGLE_WIDTH_IN, height = HEIGHT_IN, bg = "white")


